# API Keys
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here
SEARCH_API_KEY=your_serpapi_key_here

# Voice Configuration
VOICE_NAME=en-US-GuyNeural
MIC_DEVICE_INDEX=0
WAKE_WORD=jarvis
ENABLE_WAKE_WORD=1

# User Configuration
USER_NAME=Fizan
ASSISTANT_NAME=Jarvis

# Memory Configuration
MEMORY_MAX_ITEMS=1000
MEMORY_TTL_DAYS=90
DATABASE_PATH=./data/jarvis.db

# Search Configuration
AUTO_WEB_SEARCH_ENABLE=1
AUTO_NEWS_ENABLE=1
AUTO_WEATHER_ENABLE=1

# Offline Mode
OFFLINE_MODE=0
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Command Security
COMMAND_ALLOWLIST=
COMMAND_DENYLIST=rm,format,shutdown,reboot,del,wipe

# Logging
LOG_LEVEL=INFO
LOG_PATH=./logs
